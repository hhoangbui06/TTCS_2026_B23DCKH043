mixin alert-success(time)
    -if(messages.success)
        .message.info
            .alert.alert-success(data-time=time, show-alert) #{messages.success} <span close-alert>&times;</span>

mixin alert-error(time)
    -if(messages.titleError)
        .message.info
            .alert.alert-danger(data-time=time, show-alert) #{messages.error} <span close-alert>&times;</span>
