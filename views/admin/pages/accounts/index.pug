extends ../../layouts/default.pug
include ../../mixins/alert.pug
block main
  h1(class="mb-4") Tài khoản
  +alert-success(3000)
  +alert-error(5000)
  .card.mb-3
    .card-header Danh sách tài khoản
    .card-body
      .row
        .col-8
        .col-4.text-right
          if(role.permissions.includes('account_create'))
            a( 
              href=`${prefixAdmin}/accounts/create`
              class="btn btn-outline-success"
            ) + Thêm mới
      table(
        class="table table-hover table-sm"
      )
        thead
          tr
            th STT
            th Avatar
            th Họ tên
            th Phân quyền
            th Email
            th Trạng thái
            th Hành động
        tbody
          each item, index in records
            tr
              td #{index+1}
              td
                img(
                  src=item.avatar
                  alt=item.fullName
                  width="100px"
                  height="auto"
                )
              td #{item.fullName}
                td!= item.role
              td #{item.email}
              td
                a(
                  href="javascript:;"
                  class=item.badge
                  data-id=item._id
                  data-status=item.status
                  button-account-change-status=role.permissions.includes('account_edit')
                ) #{item.stt}
                
              td
                a(
                  class="btn btn-info btn-sm"
                  href=`${prefixAdmin}/accounts/detail/${item.id}`
                ) Chi tiết
                if(role.permissions.includes('account_edit'))
                  a(
                    class="btn btn-warning btn-sm ml-1"
                    href=`${prefixAdmin}/accounts/edit/${item.id}`
                  ) Sửa
                if(role.permissions.includes('account_delete'))
                  button(
                    class="btn btn-danger btn-sm ml-1"
                    data-id=item._id
                    button-account-delete
                  ) Xóa
          else
            tr
              td(colspan='4' class="text-center") Chưa có tài khoản nào được tạo!
          form(
            method="POST"
            action=""
            data-path=`${prefixAdmin}/accounts/delete`
            form-account-delete
          )
  form(
    action=""
    method="POST"
    data-path=`${prefixAdmin}/accounts/delete`
    form-account-delete
  )
  form(
    action=""
    method="POST"
    data-path=`${prefixAdmin}/accounts/change-status`
    form-account-change-status
  )
  script(src="/admin/js/account.js")