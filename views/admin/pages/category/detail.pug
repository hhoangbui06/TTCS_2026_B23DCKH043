extends ../../layouts/default.pug

block main
    -if (category.title)
        h1(class='mb-4') #{category.title}
    -if (category.thumbnail)
        div(class='mb-4')
            img(
                src=category.thumbnail
                style="width:100px"
            )
    -if (category.status)
        div(class='mb-4')
            span Trạng thái:
            if (category.status==="active")
                span(class="badge badge-success") Hoạt động
            else
                span(class="badge badge-danger") Dừng hoạt động
    -if (category.position)
        div(class='mb-4') Vị trí: <b>#{category.position}</b>
    -if (category.description)
        div(class='mb-4') Mô tả danh mục: !{category.description}
    a(href=`${prefixAdmin}/categories/edit/${category._id}` class='btn btn-info') Chỉnh sửa
    
    script(src='/admin/js/category.js')
