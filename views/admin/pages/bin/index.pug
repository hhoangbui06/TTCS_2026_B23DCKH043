extends ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/form-search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug 
include ../../mixins/sort-select.pug
include ../../mixins/formatDateTime.pug


block main
    h1 Sản phẩm đã xóa
    +alert-success(3000)
    +alert-error(5000)
    .card.mb-3
        .card-header Bộ lọc và tìm kiếm
        .card-body
            .row
                .col-6
                  +form-search("form-search-bin", keyword)
    +sort-select()
    .card.mb-3
        .card-header Danh sách
        .card-body
            .row                    
                .col-8
                    +form-change-multi-bin(prefixAdmin+`/bin/change-multi?_method=PATCH`, `${prefixAdmin}/bin/recovery-all`)
            hr    
            table(class="table table-hover table-sm text-center" checkbox-multi)
                thead
                    tr
                        th
                            input(type="checkbox" name="checkall")
                        th STT
                        th Hình ảnh
                        th Tên sản phẩm
                        th Giá gốc
                        th Vị trí
                        th Hành động
                        th Người xóa
                -let index=1
                tbody                               
                    -for(let product of products)
                        tr
                            td
                                input(
                                    type="checkbox"
                                    name="id"
                                    value=product._id
                                    data-position=product.position
                                )
                            td #{index++}
                            td
                                img(src=product.thumbnail
                                    alt=!product.description
                                    width="100px"
                                    height="auto"
                                )
                            td #{product.title}
                            td #{product.price}$
                            td #{product.position}
                            td
                              
                              a(
                                href=`${prefixAdmin}/products/detail/${product._id}`
                                class="btn btn-primary btn-sm" data-id=product._id
                              ) Chi tiết
                              if(role.permissions.includes('product_delete'))
                                button(class="btn btn-danger btn-sm ml-1" data-id=product._id button-delete) Xóa
                              if(role.permissions.includes('product_recovery'))
                                button(class="btn btn-success btn-sm ml-1" data-id=product._id button-recovery) Khôi phục
                            td
                              if(product.deleteUser)
                                if(role.permissions.includes('account_views'))
                                  a(
                                    href=`${prefixAdmin}/accounts/detail/${product.deleteUser._id}`
                                  ) #{product.deleteUser.fullName}
                                else
                                  b #{product.deleteUser.fullName}
                                +formatDateTime(product.deletedBy.deletedAt)
                              else
                                p <i>Không có dữ liệu</i>
                              
    form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`${prefixAdmin}/bin/delete`
    )
    form(
      action=""
      method="POST"
      data-path=`${prefixAdmin}/bin/recovery`
      id="form-recovery-item"
    )
    script(src="/admin/js/bin.js")