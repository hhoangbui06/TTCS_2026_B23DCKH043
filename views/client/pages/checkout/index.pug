extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
  +alert-success(3000)
  +alert-error(5000)

  .container.my-3
    .row
      .col-12
        +box-head(title)
    
    .row
      .col-12
        -let index=1
        table(class="table table-bordered")
          thead
            tr
              th STT
              th Ảnh
              th Tên
              th Giá
              th Số lượng
              th Tổng tiền
          tbody
            if(cartDetail.length>0)
              -for(let item of cartDetail)
                tr
                  td #{index++}
                  td
                    img(src=item.product.thumbnail, alt=item.product.description width="80px")
                  td
                    a(href=`/products/details/${item.product.slug}`) #{item.product.title}
                  td #{item.product.priceNew} $
                  td #{item.quantity}
                  td #{item.product.priceNew*item.quantity} $
            else
              tr
                td(colspan='7')
                  h3.text-center Chưa có sản phẩm nào được thêm!
        h3(class="text-right") Tổng đơn hàng: #{cartDetail.totalPrice || 0} $
    if(cartDetail.length>0)
      .row
        .col-12
          .card.p-4.my-4
            form(
              action="checkout/order"
              method="POST"
            )
              div(class="form-group")
                label(for="fullName") Họ tên
                input(
                  type="text"
                  class="form-control"
                  id="fullName"
                  name="fullName"
                  value=user.fullName||""
                  required
                )
              div(class="form-group")
                label(for="phone") Số điện thoại
                input(
                  type="text"
                  class="form-control"
                  id="phone"
                  name="phone"
                  value=user.phone||""
                  required
                )
              div(class="form-group")
                label(for="address") Địa chỉ
                input(
                  type="text"
                  class="form-control"
                  id="address"
                  name='address'
                  value=user.address||""
                  required
                )
              div(class="form-group")
                button(
                  type="submit"
                  class="btn btn-success btn-block"
                ) ĐẶT HÀNG
