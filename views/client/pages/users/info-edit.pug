extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  
  +alert-error(5000)
  +alert-success(3000)

  .container.my-5
    .row.justify-content-center
      .col-8
        h1(class="mb-4") Cập nhật tài khoản
        form(
          action=`/users/info/edit?_method=PATCH`
          method="POST"
          enctype="multipart/form-data"
        )
          div(class="form-group")
            label(for="fullName") Họ tên *
              input(
                type="text"
                class="form-control"
                id="fullName"
                name="fullName"
                value=user.fullName
              )
          div(
            class="form-group"
            upload-image
          )    
            label(for="avatar") Avatar
            button(id="clear-input-image" class="btn-hidden" type="button") &times;  
            input(
              type="file"
              class="form-control-file"
              id="avatar"
              name="avatar"
              accept="image/*"
              upload-image-input
            )
            input(
              type="hidden"
              name="avatar"
              value=user.avatar || ""
            )
            img(
              src=user.avatar || ""
              class="image-preview"
              upload-image-preview
            )
          div(class="form-group")
            label(for="email") Email *
              input(
                type="email"
                class="form-control"
                id="email"
                name="email"
                value=user.email
              )
          div(class="form-group")
            label(for="password") Mật khẩu 
              input(
                type="password"
                class="form-control"
                id="password"
                name="password"
              )
          div(class="form-group")
            label(for="confirmPassword") Xác nhận mật khẩu (nếu có thay đổi)
              input(
                type="password"
                class="form-control"
                id="confirmPassword"
                name="confirmPassword"
              )
          div(class="form-group")
            label(for="phone") Phone
              input(
                type="text"
                class="form-control"
                id="phone"
                name="phone"
                value=user.phone
              )
          div(class="form-group")
            label(for="address") Address
              input(
                type="text"
                class="form-control"
                id="address"
                name="address"
                value=user.address
              )

          div(class="form-group")
            button(
              type="submit"
              class="btn btn-primary"
            ) Cập nhật