extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../../admin/mixins/pagination.pug
include ../../../admin/mixins/form-search.pug



block main
    .container.my-3
        .row
            .col-12
                .box-head
                    +box-head("Danh sách sản phẩm")
        br
        .card-body
            .row
                .col-6
                    +form-search(keyword)
        .row
            -for (let product of products)
                .col-4.mb-3
                    .product-item
                        .inner-image
                            img(src=product.thumbnail, alt=product.description)
                        .inner-content
                            h3.inner-title 
                                a(href=`/products/details/${product.slug}`) #{product.title}
                            .inner-price-new #{product.priceNew}$
                            .inner-price-old #{product.price}$
                            .inner-discount -#{product.discountPercentage}% 
        +pagination(objectPagination)
    script(src='/client/js/product.js')
